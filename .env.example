#--- config de desarrollo
NODE_ENV2=development
# Activa modo producción (deshabilita synchronize y logging de TypeORM)
NODE_ENV2=production

# SSL requerido por Aiven
DB_SSL=true
# ─── BASE DE DATOS ─────────────────────────────────────────────────────────────
# Configuración de conexión a MySQL
# Para cambiar la BD: modificar estos valores y reiniciar el servidor
DB_HOST=localhost
DB_PORT=3306
DB_NAME=turnopro_db
DB_USER=root
DB_PASS=

#DB_HOST=turnopro-db-tuturno-pro.a.aivencloud.com
#DB_PORT=19410
#DB_NAME=defaultdb
#DB_USER=avnadmin
#DB_PASS=AVNS_eunuMvAc_R7awgGukAc


# ─── JWT ───────────────────────────────────────────────────────────────────────
# Clave secreta para firmar tokens. MÍNIMO 32 caracteres. NUNCA exponerla al frontend
# Para cambiar: generar una nueva clave aleatoria y actualizar aquí
JWT_SECRET=cambia_esto_por_una_clave_secreta_de_minimo_32_caracteres
# Tiempo de expiración del token. Formato: 7d, 24h, 60m
JWT_EXPIRY=7d

# ─── EMAIL (SMTP) ──────────────────────────────────────────────────────────────
# Configuración para envío de emails con Nodemailer
# Para usar Gmail: activar "Contraseñas de aplicación" en la cuenta de Google
# Para cambiar proveedor: actualizar host, port y credenciales
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
#MAIL_USER=ing.cheo@gmail.com
#MAIL_PASS=ucymccekdkajmsew
MAIL_USER=tuturnopro@gmail.com
MAIL_PASS=fvdszjtjtegyygqb
MAIL_FROM="TurnoPro <noreply@turnopro.com>"

# ─── APLICACIÓN ────────────────────────────────────────────────────────────────
# URL base del frontend. Se usa para generar links en emails y mensajes WhatsApp
# En desarrollo: http://localhost:5173
# En producción: https://turnopro.com
APP_URL=http://localhost:5173
# Puerto del servidor backend
PORT=3000

# ─── REGLAS DE NEGOCIO ─────────────────────────────────────────────────────────
# Horas para expirar citas PENDING sin acción del profesional
# Impacta: AppointmentsService.expirePendingAppointments() y el cron job
# Para cambiar: modificar este valor. El cron revisará con la nueva regla automáticamente
PENDING_EXPIRY_HOURS=2

# ─── SUPERADMIN INICIAL ────────────────────────────────────────────────────────
# Credenciales del primer superadmin creado al ejecutar el seed
# Solo se usa en: src/database/seeds/superadmin.seed.ts
# Cambiar ANTES de ejecutar el seed por primera vez
SUPERADMIN_EMAIL=admin@turnopro.com
SUPERADMIN_PASS=Admin123!
